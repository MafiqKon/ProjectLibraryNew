@model IEnumerable<ProjectLibrary.Controllers.AdminUserViewModel>

@{
    ViewData["Title"] = "Управление на потребители";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 mt-3 gap-3">
    <div class="d-flex align-items-center">
        <i data-lucide="users" class="me-2 text-primary" style="width: 28px; height: 28px;"></i>
        <h2 class="fw-bold mb-0" style="color: var(--text-main);">Управление на потребители</h2>
    </div>

    <div class="d-flex flex-column flex-md-row gap-3">
        <form asp-action="Users" method="get" class="m-0">
            <div class="input-group shadow-sm" style="border-radius: 50px; overflow: hidden; background-color: var(--bg-card); border: 1px solid var(--border-color);">
                <span class="input-group-text bg-transparent border-0 pe-1" style="color: var(--text-muted);">
                    <i data-lucide="search" style="width: 18px;"></i>
                </span>
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-0 shadow-none bg-transparent" placeholder="Търси по име или имейл..." style="color: var(--text-main); min-width: 250px;" />
                <button type="submit" class="btn fw-bold px-3" style="background-color: var(--bg-card-nested); color: var(--text-main); border-left: 1px solid var(--border-color);">
                    Търси
                </button>
                @if (ViewData["CurrentFilter"] != null)
                {
                    <a asp-action="Users" class="btn btn-danger d-flex align-items-center px-3" title="Изчисти">
                        <i data-lucide="x" style="width: 16px; margin:0;"></i>
                    </a>
                }
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden mb-5" style="background-color: var(--bg-card); border: 2px solid var(--border-color) !important; border-radius: 16px; transform: none !important; transition: none !important;">
    <div class="table-responsive">
        <table class="table align-middle mb-0" style="color: var(--text-main);">
            <thead style="background-color: rgba(150, 150, 150, 0.05);">
                <tr>
                    <th class="py-3 px-4 border-bottom-0 fw-bold">Аватар</th>
                    <th class="py-3 px-4 border-bottom-0 fw-bold">Име и Фамилия</th>
                    <th class="py-3 px-4 border-bottom-0 fw-bold">Имейл</th>
                    <th class="py-3 px-4 border-bottom-0 fw-bold">Тип/Смяна на роля</th>
                    <th class="py-3 px-4 border-bottom-0 fw-bold text-center">Статистика</th>
                    <th class="py-3 px-4 border-bottom-0 fw-bold text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid var(--border-color);">
                            <td class="py-3 px-4">
                                @if (!string.IsNullOrEmpty(item.User.ProfilePictureUrl))
                                {
                                    <img src="@item.User.ProfilePictureUrl" alt="Avatar" class="rounded-circle shadow-sm" style="width: 45px; height: 45px; object-fit: cover; border: 2px solid var(--bg-body);" />
                                }
                                else
                                {
                                    <div class="rounded-circle shadow-sm d-flex justify-content-center align-items-center" style="width: 45px; height: 45px; background-color: var(--bg-body); color: var(--text-muted); border: 2px solid var(--border-color);">
                                        <i data-lucide="user" style="width: 20px; height: 20px;"></i>
                                    </div>
                                }
                            </td>
                            <td class="py-3 px-4 fw-bold" style="font-size: 1.05rem;">@item.User.FirstName @item.User.LastName</td>
                            <td class="py-3 px-4 text-muted">@item.User.Email</td>

                            <td class="py-3 px-4">
                                @if (item.User.UserName == "admin@abv.bg")
                                {
                                    <div class="role-superadmin shadow-sm">
                                        СУПЕРАДМИН <i data-lucide="chevron-down" style="width: 18px; margin-left: 8px; opacity: 0.5;"></i>
                                    </div>
                                }
                                else
                                {
                                    <form asp-action="ChangeUserRole" method="post" class="m-0">
                                        <input type="hidden" name="userId" value="@item.User.Id" />
                                        @{
                                            var currentRole = item.User.UserType.ToString();
                                        }

                                        <div class="role-selector-wrapper role-@currentRole.ToLower() shadow-sm">
                                            <select name="newRole" class="custom-role-select" onchange="this.form.submit()">
                                                <option value="Student" class="bg-white text-dark" selected="@(currentRole == "Student")">Ученик</option>
                                                <option value="Teacher" class="bg-white text-dark" selected="@(currentRole == "Teacher")">Учител</option>

                                                @if (ViewBag.IsSuperAdmin)
                                                {
                                                    <option value="Admin" class="bg-white text-dark" selected="@(currentRole == "Admin")">Админ</option>
                                                }
                                                else if (currentRole == "Admin")
                                                {
                                                    <option value="Admin" class="bg-white text-dark" selected="true" disabled>Админ</option>
                                                }
                                            </select>
                                            <i data-lucide="chevron-down" class="role-chevron"></i>
                                        </div>
                                    </form>
                                }
                            </td>

                            <td class="py-3 px-4 text-center small text-muted">
                                <div class="d-flex justify-content-center align-items-center gap-2">
                                    <span title="Колекции" class="d-flex align-items-center"><i data-lucide="layers" class="me-1 text-primary" style="width: 14px;"></i> @item.CollectionsCount кол.</span>
                                    <span style="color: var(--border-color);">|</span>
                                    <span title="Коментари" class="d-flex align-items-center"><i data-lucide="message-circle" class="me-1 text-info" style="width: 14px;"></i> @item.CommentsCount ком.</span>
                                </div>
                            </td>

                            <td class="py-3 px-4 text-end">
                                <div class="d-flex justify-content-end align-items-center gap-2">
                                    @if (item.User.UserName == "admin@abv.bg")
                                    {
                                        <span class="text-muted small fw-bold me-2"><i data-lucide="lock" style="width: 14px; margin-right: 4px;"></i>Защитен</span>
                                    }
                                    else if (item.User.UserType == ProjectLibrary.Models.UserType.Admin && !ViewBag.IsSuperAdmin)
                                    {
                                        <span class="text-muted small fw-bold me-2"><i data-lucide="shield" style="width: 14px; margin-right: 4px;"></i>Админ</span>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-outline-warning btn-sm d-flex justify-content-center align-items-center hover-scale m-0"
                                                style="width: 34px; height: 34px; border-width: 2px; border-radius: 10px; padding: 0;"
                                                title="Смени паролата"
                                                onclick="openPasswordModal('@item.User.Id', '@item.User.FirstName @item.User.LastName')">
                                            <i data-lucide="key" style="width: 16px; margin: 0;"></i>
                                        </button>

                                        <form asp-action="DeleteUser" method="post" style="display:inline;" class="m-0">
                                            <input type="hidden" name="userId" value="@item.User.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm d-flex justify-content-center align-items-center hover-scale m-0"
                                                    style="width: 34px; height: 34px; border-width: 2px; border-radius: 10px; padding: 0;"
                                                    onclick="return confirm('Сигурни ли сте, че искате да изтриете този потребител? Всички негови коментари ще бъдат изтрити!')"
                                                    title="Изтрий потребител">
                                                <i data-lucide="trash-2" style="width: 16px; margin: 0;"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i data-lucide="users" class="mb-3 opacity-50" style="width: 48px; height: 48px;"></i>
                            <h5 class="fw-bold">Няма намерени потребители</h5>
                            <p class="mb-0">Опитайте друго търсене.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 16px; background-color: var(--bg-card);">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" style="color: var(--text-main);">
                    <i data-lucide="key" class="me-2 text-warning" style="width: 24px;"></i> Смяна на парола
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-4">Въведете нова парола за потребител <strong id="resetUserName" class="text-primary"></strong>.</p>

                <form asp-action="ResetUserPassword" method="post">
                    <input type="hidden" id="resetUserId" name="userId" />

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase">Нова парола</label>
                        <input type="text" name="newPassword" class="form-control rounded-3 py-2" required minlength="6" placeholder="Напр. NovaParola123!" style="background-color: var(--bg-body); border-color: var(--border-color); color: var(--text-main);">
                        <small class="text-muted d-block mt-2" style="font-size: 0.8rem;">Внимание: Паролата трябва да съдържа главна буква, малка буква, цифра и специален знак (според изискванията на системата).</small>
                    </div>

                    <button type="submit" class="btn w-100 rounded-pill fw-bold shadow-sm hover-scale d-flex align-items-center justify-content-center" style="background-color: #f59e0b; color: white; padding: 12px; border: none;">
                        <i data-lucide="save" class="me-2" style="width: 18px;"></i> Запази новата парола
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* Базов стил за контейнера на падащото меню */
    .role-selector-wrapper {
        position: relative;
        display: inline-block;
        border-radius: 50px;
        width: 140px;
    }

    /* Скриваме стандартния грозен дизайн на браузъра за <select> */
    .custom-role-select {
        appearance: none;
        -webkit-appearance: none;
        background: transparent !important;
        border: 2px solid;
        border-radius: 50px;
        padding: 8px 35px 8px 16px; /* Оставяме място вдясно за човката */
        font-weight: 600;
        font-size: 0.95rem;
        width: 100%;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .custom-role-select:focus {
            box-shadow: none;
            outline: none;
            filter: brightness(1.2);
        }

    /* Позиционираме нашата собствена красива човка (Lucide icon) */
    .role-chevron {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none; /* Много важно: Позволява кликане през иконката */
        width: 18px;
        height: 18px;
    }

    /* ============================== */
    /* ЦВЕТОВЕ СПОРЕД РОЛЯТА          */
    /* ============================== */

    /* 🟢 УЧЕНИК */
    .role-student .custom-role-select {
        background-color: #113220 !important;
        color: #90C7A8 !important;
        border-color: #1B4D31 !important;
    }

    .role-student .role-chevron {
        color: #90C7A8;
    }

    /* 🟠 УЧИТЕЛ */
    .role-teacher .custom-role-select {
        background-color: #42280E !important;
        color: #EAB676 !important;
        border-color: #664115 !important;
    }

    .role-teacher .role-chevron {
        color: #EAB676;
    }

    /* 🔴 АДМИН */
    .role-admin .custom-role-select {
        background-color: #4F111E !important;
        color: #F494A5 !important;
        border-color: #7A1A2E !important;
    }

    .role-admin .role-chevron {
        color: #F494A5;
    }

    /* 👑 СУПЕРАДМИН (Не е падащо меню, само бадж) */
    .role-superadmin {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background-color: #212121;
        color: #E2C06B;
        border: 2px solid #3D3D3D;
        border-radius: 50px;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 0.95rem;
        width: 160px;
        cursor: default;
    }
</style>

@section Scripts {
    <script>
        // Презареждаме иконките, в случай че сме ги инжектирали
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }

        // Функция за отваряне на модала и зареждане на данните
        function openPasswordModal(id, name) {
            document.getElementById('resetUserId').value = id;
            document.getElementById('resetUserName').innerText = name;
            var modal = new bootstrap.Modal(document.getElementById('resetPasswordModal'));
            modal.show();
        }
    </script>
}