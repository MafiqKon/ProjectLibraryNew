@model IEnumerable<ProjectLibrary.Models.ApplicationUser>

@{
    ViewData["Title"] = "Чакащи учители";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 mt-3 gap-3">
    <div class="d-flex align-items-center">
        <div class="p-2 bg-warning bg-opacity-10 rounded-circle me-3 d-flex justify-content-center align-items-center" style="width: 48px; height: 48px;">
            <i data-lucide="clock" class="text-warning" style="width: 24px; height: 24px;"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0" style="color: var(--text-main);">Заявки за Учители</h2>
            <p class="text-muted small mb-0">Потребители, които желаят учителски права</p>
        </div>
    </div>
    <a asp-action="Users" class="btn btn-outline-primary rounded-pill fw-bold px-4 hover-scale">
        <i data-lucide="users" class="me-2" style="width: 18px;"></i> Всички потребители
    </a>
</div>

@if (!Model.Any())
{
    <div class="custom-card p-5 text-center shadow-sm" style="background-color: var(--bg-card); border-radius: 16px;">
        <div class="d-inline-flex justify-content-center align-items-center rounded-circle mb-4" style="width: 80px; height: 80px; background-color: rgba(16, 185, 129, 0.1);">
            <i data-lucide="check-circle" class="text-success" style="width: 40px; height: 40px;"></i>
        </div>
        <h4 class="fw-bold mb-2" style="color: var(--text-main);">Всичко е наред!</h4>
        <p class="text-muted mb-0">Няма нови чакащи заявки за учителски профили.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var user in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="custom-card h-100 p-4 position-relative overflow-hidden shadow-sm" style="background-color: var(--bg-card); border-radius: 16px; border-top: 4px solid #f59e0b !important;">

                    <div class="d-flex align-items-center mb-4">
                        @if (!string.IsNullOrEmpty(user.ProfilePictureUrl))
                        {
                            <img src="@user.ProfilePictureUrl" alt="Avatar" class="rounded-circle shadow-sm me-3" style="width: 55px; height: 55px; object-fit: cover; border: 2px solid var(--border-color);" />
                        }
                        else
                        {
                            <div class="rounded-circle shadow-sm d-flex justify-content-center align-items-center me-3" style="width: 55px; height: 55px; background-color: var(--bg-body); color: var(--text-muted); border: 2px solid var(--border-color);">
                                <i data-lucide="user" style="width: 24px; height: 24px;"></i>
                            </div>
                        }
                        <div>
                            <h5 class="fw-bold mb-0" style="color: var(--text-main);">@user.FirstName @user.LastName</h5>
                            <small class="text-muted">@user.Email</small>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4 text-muted small fw-bold">
                        <i data-lucide="calendar" class="me-2 text-warning" style="width: 16px;"></i> Регистриран на: @user.RegistrationDate.ToString("dd.MM.yyyy HH:mm")
                    </div>

                    <div class="d-flex gap-2 mt-auto">
                        <form asp-action="ApproveTeacher" method="post" class="w-50 m-0">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold shadow-sm d-flex justify-content-center align-items-center hover-scale">
                                <i data-lucide="check" class="me-1" style="width: 18px;"></i> Одобри
                            </button>
                        </form>

                        <form asp-action="RejectTeacher" method="post" class="w-50 m-0">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn w-100 rounded-pill fw-bold d-flex justify-content-center align-items-center hover-scale" style="background-color: transparent; border: 2px solid #dc3545; color: #dc3545;" onclick="return confirm('Сигурни ли сте? Потребителят ще остане със статут Ученик.')">
                                <i data-lucide="x" class="me-1" style="width: 18px;"></i> Отхвърли
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    </script>
}