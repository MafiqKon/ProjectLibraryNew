@model IEnumerable<ProjectLibrary.Models.Comment>

@{
    ViewData["Title"] = "Управление на коментари";
    Layout = "_Layout"; // Или твоят административен леяут
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-chat-dots"></i> Управление на коментари</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад към таблото</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Дата</th>
                            <th>Потребител</th>
                            <th>Произведение</th>
                            <th>Коментар</th>
                            <th class="text-center">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var comment in Model)
                        {
                            <tr>
                                <td style="width: 150px;">
                                    @comment.CreatedDate.ToString("dd.MM.yyyy HH:mm")
                                </td>
                                <td style="width: 200px;">
                                    <strong>@comment.User?.UserName</strong>
                                    <br />
                                    <small class="text-muted">ID: @comment.UserId</small>
                                </td>
                                <td style="width: 200px;">
                                    <span class="badge bg-info text-dark">@comment.Book?.Title</span>
                                </td>
                                <td>
                                    <div class="text-truncate" style="max-width: 400px;" title="@comment.Content">
                                        @comment.Content
                                    </div>
                                </td>
                                <td class="text-center">
                                    <form asp-action="DeleteComment" method="post" onsubmit="return confirm('Сигурни ли сте, че искате да изтриете този коментар?');">
                                        <input type="hidden" name="id" value="@comment.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="bi bi-trash"></i> Изтрий
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <p class="text-muted">Няма открити коментари в системата.</p>
                </div>
            }
        </div>
    </div>
</div>