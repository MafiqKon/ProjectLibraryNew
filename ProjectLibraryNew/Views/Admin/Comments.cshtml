@model IEnumerable<ProjectLibrary.Models.Comment>

@{
    ViewData["Title"] = "Управление на коментари";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: var(--primary);">💬 Управление на коментари</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card shadow-sm border-0" style="background-color: var(--bg-card);">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: var(--bg-body); color: var(--text-main);">
                        <tr>
                            <th>Потребител</th>
                            <th>Книга</th>
                            <th style="width: 45%;">Коментар</th>
                            <th>Дата</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var comment in Model)
                            {
                                <tr style="color: var(--text-main);">
                                    <td class="fw-bold">
                                        @(comment.User != null ? comment.User.FirstName + " " + comment.User.LastName : "Анонимен")
                                    </td>

                                    <td class="text-muted small">
                                        @(comment.Book != null ? comment.Book.Title : "Неизвестна книга")
                                    </td>

                                    <td>
                                        <div style="max-height: 60px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;" title="@comment.Content">
                                            @comment.Content
                                        </div>
                                    </td>

                                    <td class="small text-muted">
                                        @comment.CreatedDate.ToString("dd.MM.yyyy HH:mm")
                                    </td>

                                    <td class="text-end">
                                        <form asp-controller="Admin" asp-action="DeleteComment" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@comment.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger fw-bold" onclick="return confirm('Сигурни ли сте, че искате да изтриете този коментар завинаги?')">
                                                🗑️ Изтрий
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <h5 class="fw-bold mb-0">Все още няма написани коментари в сайта.</h5>
                                    <small>Когато някой ученик коментира книга, коментарът ще се появи тук.</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>