@{
    ViewData["Title"] = "Нова колекция";
}

<h2>➕ Нова колекция</h2>

<form method="post" asp-action="Create">
    @Html.AntiForgeryToken()

    <div class="card">
        <div class="card-body">
            <div class="form-group mb-3">
                <label class="form-label">Име на колекция *</label>
                <input type="text" name="Name" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label class="form-label">Описание</label>
                <textarea name="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-check mb-3">
                <input type="checkbox" name="IsPublic" class="form-check-input" checked />
                <label class="form-check-label">Публична колекция</label>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">💾 Създай колекция</button>
                <a asp-action="Index" class="btn btn-secondary">← Назад</a>
            </div>
        </div>
    </div>
</form>