@model ProjectLibrary.Models.BookCollection

@{
    ViewData["Title"] = "Детайли за колекция";
}

<h2>📚 @Model.Name</h2>

<div class="card mb-4">
    <div class="card-body">
        <p class="card-text">@Model.Description</p>
        <p class="text-muted">
            📅 Създадена на: @Model.CreatedDate.ToString("dd.MM.yyyy") |
            🌐 @(Model.IsPublic ? "Публична" : "Частна")
        </p>
    </div>
</div>

<h4>📖 Книги в колекцията (@Model.Books.Count)</h4>

@if (Model.Books.Any())
{
    <div class="row">
        @foreach (var book in Model.Books)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@book.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@book.Author.Name</h6>
                        <p class="card-text">@book.Genre • @book.StudyYear клас</p>
                        <a href="@Url.Action("Details", "Books", new { id = book.Id })" class="btn btn-outline-primary btn-sm">👀 Виж детайли</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">
        📭 Все още няма книги в тази колекция.
        <a href="@Url.Action("AddBook", new { collectionId = Model.Id })" class="alert-link">Добавете първата книга</a>
    </div>
}

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">← Назад към колекциите</a>
    <a href="@Url.Action("AddBook", new { collectionId = Model.Id })" class="btn btn-primary">➕ Добави книга</a>
</div>