@{
    ViewData["Title"] = "Учителски панел";
}

<div class="d-flex align-items-center mb-4 mt-3 pb-3 border-bottom" style="border-color: var(--border-color) !important;">
    <div class="flex-shrink-0 d-flex justify-content-center align-items-center shadow-sm me-3"
         style="width: 56px; height: 56px; background-color: var(--primary); border-radius: 16px;">
        <i data-lucide="graduation-cap" style="color: white; width: 32px; height: 32px; stroke-width: 1.5;"></i>
    </div>
    <div class="d-flex flex-column justify-content-center">
        <h2 class="fw-bold mb-1" style="color: var(--text-main); line-height: 1;">Учителски панел</h2>
        <p class="text-muted mb-0" style="line-height: 1.2;">Управление на класове, тестове и ученици</p>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card h-100 border-0 shadow-sm text-center p-4" style="background-color: var(--bg-card); border-radius: 16px;">
            <div class="d-flex justify-content-center mb-3">
                <div class="rounded-circle d-flex justify-content-center align-items-center bg-primary bg-opacity-10 text-primary" style="width: 50px; height: 50px;">
                    <i data-lucide="users" style="width: 24px;"></i>
                </div>
            </div>
            <h2 class="fw-bold mb-1" style="color: var(--text-main);">0</h2>
            <h6 class="fw-bold mb-1" style="color: var(--text-main);">Студенти</h6>
            <p class="text-muted small mb-0">0 активни</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 border-0 shadow-sm text-center p-4" style="background-color: var(--bg-card); border-radius: 16px;">
            <div class="d-flex justify-content-center mb-3">
                <div class="rounded-circle d-flex justify-content-center align-items-center bg-info bg-opacity-10 text-info" style="width: 50px; height: 50px;">
                    <i data-lucide="file-text" style="width: 24px;"></i>
                </div>
            </div>
            <h2 class="fw-bold mb-1" style="color: var(--text-main);">0</h2>
            <h6 class="fw-bold mb-1" style="color: var(--text-main);">Тестове</h6>
            <p class="text-muted small mb-0">Създадени</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 border-0 shadow-sm text-center p-4" style="background-color: var(--bg-card); border-radius: 16px;">
            <div class="d-flex justify-content-center mb-3">
                <div class="rounded-circle d-flex justify-content-center align-items-center bg-success bg-opacity-10 text-success" style="width: 50px; height: 50px;">
                    <i data-lucide="book-open" style="width: 24px;"></i>
                </div>
            </div>
            <h2 class="fw-bold mb-1" style="color: var(--text-main);">0</h2>
            <h6 class="fw-bold mb-1" style="color: var(--text-main);">Книги</h6>
            <p class="text-muted small mb-0">0 за матура</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 border-0 shadow-sm text-center p-4" style="background-color: var(--bg-card); border-radius: 16px;">
            <div class="d-flex justify-content-center mb-3">
                <div class="rounded-circle d-flex justify-content-center align-items-center text-warning" style="width: 50px; height: 50px; background-color: rgba(245, 158, 11, 0.1);">
                    <i data-lucide="activity" style="width: 24px;"></i>
                </div>
            </div>
            <h2 class="fw-bold mb-1" style="color: var(--text-main);">0</h2>
            <h6 class="fw-bold mb-1" style="color: var(--text-main);">Активни</h6>
            <p class="text-muted small mb-0">Сесии</p>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100" style="background-color: var(--bg-card); border-radius: 16px;">
            <div class="card-header border-0 bg-transparent pt-4 pb-2">
                <h5 class="fw-bold mb-0" style="color: var(--text-main);">
                    <i data-lucide="zap" class="me-2" style="color: #eab308; fill: #eab308; width: 22px;"></i> Бързи действия
                </h5>
            </div>
            <div class="card-body">
                <div class="d-flex flex-column gap-3">
                    <a href="@Url.Action("Create", "Tests")" class="btn btn-solid-premium shadow-sm w-100 d-flex justify-content-center align-items-center py-2 fw-bold hover-scale" style="border-radius: 50rem !important;">
                        <i data-lucide="plus-square" class="me-2" style="width: 18px;"></i> Създай нов тест
                    </a>

                    <a href="@Url.Action("CurrentTests", "Teacher")" class="btn btn-solid-premium shadow-sm w-100 d-flex justify-content-center align-items-center py-2 fw-bold hover-scale" style="border-radius: 50rem !important;">
                        <i data-lucide="list" class="me-2" style="width: 18px;"></i> Текущи тестове
                    </a>

                    <a href="@Url.Action("Students", "Teacher")" class="btn btn-solid-premium shadow-sm w-100 d-flex justify-content-center align-items-center py-2 fw-bold hover-scale" style="border-radius: 50rem !important;">
                        <i data-lucide="users" class="me-2" style="width: 18px;"></i> Управление на студенти
                    </a>

                    <a href="@Url.Action("ClassStatistics", "Teacher")" class="btn btn-solid-premium shadow-sm w-100 d-flex justify-content-center align-items-center py-2 fw-bold hover-scale" style="border-radius: 50rem !important;">
                        <i data-lucide="bar-chart" class="me-2" style="width: 18px;"></i> Статистика на класа
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card border-0 shadow-sm h-100" style="background-color: var(--bg-card); border-radius: 16px;">
            <div class="card-header border-0 bg-transparent pt-4 pb-2">
                <h5 class="fw-bold mb-0" style="color: var(--text-main);">
                    <i data-lucide="users" class="me-2 text-primary" style="width: 22px;"></i> Последни студенти
                </h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center py-5">
                <i data-lucide="user-x" class="text-muted opacity-50 mb-3" style="width: 48px; height: 48px;"></i>
                <h6 class="fw-bold" style="color: var(--text-main);">Все още няма регистрирани студенти.</h6>
                <p class="text-muted small mb-0">Студентите ще се появят тук след регистрация.</p>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mt-4 mb-5" style="background-color: var(--bg-card); border-radius: 16px;">
    <div class="card-header border-bottom bg-transparent p-4" style="border-color: var(--border-color) !important;">
        <h5 class="fw-bold mb-0" style="color: var(--text-main);">
            <i data-lucide="info" class="me-2 text-primary" style="width: 22px;"></i> Информация за системата
        </h5>
    </div>
    <div class="card-body p-4">
        <div class="row g-4">
            <div class="col-md-6 d-flex flex-column gap-3">
                <div class="d-flex align-items-center">
                    <i data-lucide="book" class="me-3 text-success" style="width: 20px;"></i>
                    <span class="text-muted me-2">Общо книги:</span>
                    <strong style="color: var(--text-main);">0</strong>
                </div>
                <div class="d-flex align-items-center">
                    <i data-lucide="user-check" class="me-3 text-primary" style="width: 20px;"></i>
                    <span class="text-muted me-2">Активни студенти:</span>
                    <strong style="color: var(--text-main);">0</strong>
                </div>
                <div class="d-flex align-items-center">
                    <i data-lucide="bookmark" class="me-3 text-info" style="width: 20px;"></i>
                    <span class="text-muted me-2">Книги за матура:</span>
                    <strong style="color: var(--text-main);">0</strong>
                </div>
            </div>
            <div class="col-md-6 d-flex flex-column gap-3">
                <div class="d-flex align-items-center">
                    <i data-lucide="file-edit" class="me-3 text-warning" style="width: 20px;"></i>
                    <span class="text-muted me-2">Създадени тестове:</span>
                    <strong style="color: var(--text-main);">0</strong>
                </div>
                <div class="d-flex align-items-center">
                    <i data-lucide="star" class="me-3 text-warning" style="color: #eab308; fill: #eab308; width: 20px;"></i>
                    <span class="text-muted me-2">Среден успех:</span>
                    <strong style="color: var(--text-main);">0%</strong>
                </div>
                <div class="d-flex align-items-center">
                    <i data-lucide="users" class="me-3 text-secondary" style="width: 20px;"></i>
                    <span class="text-muted me-2">Общо студенти:</span>
                    <strong style="color: var(--text-main);">0</strong>
                </div>
            </div>
        </div>
    </div>
</div>