@model ProjectLibrary.Controllers.StudentViewModel

@{
    ViewData["Title"] = $"Досие: {Model.FirstName} {Model.LastName}";
    var studentBooks = ViewBag.StudentBooks as List<ProjectLibrary.Models.Book>;
    var studentTestResults = ViewBag.StudentTestResults as List<ProjectLibrary.Models.TestResult> ?? new List<ProjectLibrary.Models.TestResult>();
}

<div class="mb-3 mt-4 d-flex align-items-center">
    <button onclick="history.back()" class="btn btn-sm rounded-pill fw-bold d-inline-flex align-items-center shadow-sm px-3" style="background-color: var(--bg-body); border: 1px solid var(--border-color); color: var(--text-main);">
        <i data-lucide="arrow-left" class="me-2" style="width: 16px; height: 16px;"></i> Назад
    </button>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-5" style="background-color: var(--bg-card); overflow: hidden;">
    <div class="card-header border-0 bg-transparent p-4 d-flex align-items-center border-bottom" style="border-color: var(--border-color) !important;">
        <div class="rounded-circle d-flex justify-content-center align-items-center me-4 shadow-sm" style="width: 80px; height: 80px; background-color: var(--primary); color: white; font-size: 2rem; font-weight: bold;">
            @(Model.FirstName.Substring(0, 1))@(Model.LastName.Substring(0, 1))
        </div>
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--text-main);">@Model.FirstName @Model.LastName</h2>
            <p class="text-muted mb-0"><i data-lucide="mail" class="me-1" style="width: 16px;"></i> @Model.Email</p>
        </div>
    </div>

    <div class="card-body p-4 bg-light bg-opacity-50">
        <div class="row g-4 text-center">
            <div class="col-md-3">
                <h4 class="fw-bold text-primary mb-1">@Model.BooksCount</h4>
                <span class="text-muted small text-uppercase fw-bold">Прочетени книги</span>
            </div>
            <div class="col-md-3 border-start" style="border-color: var(--border-color) !important;">
                <h4 class="fw-bold text-success mb-1">@studentTestResults.Count</h4>
                <span class="text-muted small text-uppercase fw-bold">Решени тестове</span>
            </div>
            <div class="col-md-3 border-start" style="border-color: var(--border-color) !important;">
                <h4 class="fw-bold text-warning mb-1">@(studentTestResults.Any() ? Math.Round(studentTestResults.Average(r => r.Percentage)) : 0)%</h4>
                <span class="text-muted small text-uppercase fw-bold">Среден успех</span>
            </div>
            <div class="col-md-3 border-start" style="border-color: var(--border-color) !important;">
                <h4 class="fw-bold text-secondary mb-1">@Model.RegistrationDate.ToString("dd.MM.yyyy")</h4>
                <span class="text-muted small text-uppercase fw-bold">Регистриран на</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm rounded-4 h-100" style="background-color: var(--bg-card);">
            <div class="card-header border-0 bg-transparent pt-4 pb-2">
                <h5 class="fw-bold mb-0" style="color: var(--text-main);"><i data-lucide="pen-tool" class="me-2 text-primary" style="width: 20px;"></i> История на тестовете</h5>
            </div>
            <div class="card-body">
                @if (studentTestResults.Any())
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var result in studentTestResults.OrderByDescending(r => r.Id))
                        {
                            bool isPassed = result.Score >= (result.Test?.PassingScore ?? 50);
                            <div class="p-3 rounded-4 border shadow-sm d-flex justify-content-between align-items-center" style="background-color: var(--bg-body); border-color: var(--border-color) !important;">
                                <div>
                                    <h6 class="fw-bold mb-1" style="color: var(--text-main);">@(result.Test?.Title ?? "Изтрит тест")</h6>
                                    <small class="text-muted">Решен на: @(result.TimeSpent.TotalMinutes > 0 ? "Наскоро" : "Преди време")</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge rounded-pill px-3 py-2 mb-1 @(isPassed ? "bg-success" : "bg-danger")">
                                        @result.Percentage.ToString("0.0")% (@result.Score т.)
                                    </span>
                                    <small class="d-block text-muted fw-bold" style="font-size: 0.75rem;">
                                        @(isPassed ? "ВЗЕТ" : "НЕУСПЕШЕН")
                                    </small>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted border rounded-4" style="border-style: dashed !important;">
                        <i data-lucide="inbox" class="mb-2 opacity-50" style="width: 32px;"></i>
                        <p class="mb-0 small fw-bold">Ученикът все още не е решавал тестове.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card border-0 shadow-sm rounded-4 h-100" style="background-color: var(--bg-card);">
            <div class="card-header border-0 bg-transparent pt-4 pb-2">
                <h5 class="fw-bold mb-0" style="color: var(--text-main);"><i data-lucide="book-open" class="me-2 text-success" style="width: 20px;"></i> Прочетени произведения</h5>
            </div>
            <div class="card-body">
                @if (studentBooks != null && studentBooks.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var book in studentBooks)
                        {
                            <li class="list-group-item bg-transparent px-0 py-3 border-bottom" style="border-color: var(--border-color) !important;">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-3 bg-light d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 50px;">
                                        <i data-lucide="book" class="text-muted" style="width: 20px;"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0" style="color: var(--text-main);">@book.Title</h6>
                                        <small class="text-muted">@(book.Author?.Name ?? "Неизвестен автор")</small>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center py-4 text-muted border rounded-4" style="border-style: dashed !important;">
                        <i data-lucide="book-x" class="mb-2 opacity-50" style="width: 32px;"></i>
                        <p class="mb-0 small fw-bold">Няма добавени книги в колекциите.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    </script>
}