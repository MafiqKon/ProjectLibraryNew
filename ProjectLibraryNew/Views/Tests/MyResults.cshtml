@model IEnumerable<ProjectLibrary.Models.TestResult>

@{
    ViewData["Title"] = "Моите резултати";
    var recommendedBook = ViewBag.RecommendedBook as ProjectLibrary.Models.Book;
}

<div class="container mt-4 mb-5 pt-3">

    <div class="d-flex align-items-center mb-4 pb-2 border-bottom" style="border-color: var(--border-color) !important;">
        <i data-lucide="bar-chart-big" class="me-3" style="color: #6a9c78; width: 32px; height: 32px;"></i>
        <h2 class="fw-bold mb-0" style="color: var(--text-main);">Моето ученическо табло</h2>
    </div>

    @* --- БЛОК "ПРЕПОРЪЧАНО ЗА ТЕБ" --- *@
    @if (recommendedBook != null)
    {
        <div class="card border-0 shadow-sm rounded-4 mb-5 overflow-hidden" style="background: linear-gradient(135deg, rgba(16,185,129,0.1) 0%, rgba(59,130,246,0.1) 100%); border-left: 5px solid var(--primary) !important;">
            <div class="card-body p-4 p-md-5 position-relative">
                <i data-lucide="sparkles" class="position-absolute text-success opacity-10" style="width: 150px; height: 150px; top: -20px; right: -20px; transform: rotate(15deg);"></i>

                <div class="row align-items-center position-relative z-1">
                    <div class="col-md-8 mb-3 mb-md-0">
                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-3 fw-bold text-uppercase" style="letter-spacing: 1px;">
                            <i data-lucide="compass" class="me-1 d-inline-block" style="width: 14px; vertical-align: text-bottom;"></i> Препоръчано за теб
                        </span>
                        <h3 class="fw-bold mb-2" style="color: var(--text-main);">Време е да се упражниш върху <span class="text-primary">"@recommendedBook.Title"</span></h3>
                        <p class="text-muted mb-0" style="font-size: 1.1rem;">Все още не си се докоснал до това произведение от @(recommendedBook.Author?.Name ?? "автора"). Готов ли си за предизвикателството?</p>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <a href="@Url.Action("Details", "Books", new { id = recommendedBook.Id })" class="btn rounded-pill px-4 py-3 fw-bold shadow hover-scale d-inline-flex align-items-center text-white" style="background-color: var(--primary); border: none;">
                            <i data-lucide="rocket" class="me-2 text-white" style="width: 18px;"></i> Започни сега
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="position-fixed bottom-0 end-0 p-4" style="z-index: 1080">
            <div id="recommendationToast" class="toast border-0 shadow-lg rounded-4" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="10000">
                <div class="toast-header border-0 rounded-top-4" style="background-color: var(--primary); color: white;">
                    <i data-lucide="lightbulb" class="me-2" style="width: 18px;"></i>
                    <strong class="me-auto">Нова препоръка</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body p-3" style="background-color: var(--bg-card); color: var(--text-main);">
                    Опитай нещо ново днес! Какво ще кажеш за <strong>@recommendedBook.Title</strong>?
                    <div class="mt-3 pt-3 border-top text-end" style="border-color: var(--border-color) !important;">
                        <a href="@Url.Action("Details", "Books", new { id = recommendedBook.Id })" class="btn btn-sm rounded-pill fw-bold btn-toast-custom px-3">Виж книгата</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert border-0 shadow-sm rounded-4 mb-5 p-4 d-flex align-items-center" style="background-color: rgba(16, 185, 129, 0.1); color: #10b981;">
            <div class="rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 48px; height: 48px; background-color: rgba(16, 185, 129, 0.2);">
                <i data-lucide="trophy" style="width: 24px; height: 24px;"></i>
            </div>
            <div>
                <h5 class="fw-bold mb-1">Невероятно! 🎉</h5>
                <p class="mb-0 text-dark">Ти си преминал през всички налични произведения в системата! Очаквай нови материали скоро.</p>
            </div>
        </div>
    }
    @* --------------------------------- *@

    @if (Model.Any())
    {
        <div class="row g-4 mb-5">
            <div class="col-md-3 col-sm-6">
                <div class="stat-box-modern p-4 h-100 d-flex flex-column align-items-center justify-content-center position-relative overflow-hidden">
                    <i data-lucide="target" class="position-absolute" style="color: #6a9c78; opacity: 0.1; width: 100px; height: 100px; right: -20px; bottom: -20px;"></i>
                    <h3 class="display-5 fw-bold mb-1" style="color: #6a9c78;">@ViewBag.TotalTestsTaken</h3>
                    <span class="text-muted fw-bold text-uppercase" style="letter-spacing: 1px; font-size: 0.85rem;">Общо тестове</span>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="stat-box-modern p-4 h-100 d-flex flex-column align-items-center justify-content-center position-relative overflow-hidden">
                    <i data-lucide="percent" class="position-absolute" style="color: #6a9c78; opacity: 0.1; width: 100px; height: 100px; right: -20px; bottom: -20px;"></i>
                    <h3 class="display-5 fw-bold mb-1" style="color: var(--text-main);">@ViewBag.AverageScore%</h3>
                    <span class="text-muted fw-bold text-uppercase" style="letter-spacing: 1px; font-size: 0.85rem;">Среден успех</span>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="stat-box-modern p-4 h-100 d-flex flex-column align-items-center justify-content-center position-relative overflow-hidden">
                    <i data-lucide="check-circle" class="position-absolute" style="color: #198754; opacity: 0.1; width: 100px; height: 100px; right: -20px; bottom: -20px;"></i>
                    <h3 class="display-5 fw-bold mb-1" style="color: #198754;">@ViewBag.Passed</h3>
                    <span class="text-muted fw-bold text-uppercase" style="letter-spacing: 1px; font-size: 0.85rem;">Успешни (над 60%)</span>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="stat-box-modern p-4 h-100 d-flex flex-column align-items-center justify-content-center text-center position-relative overflow-hidden">
                    <i data-lucide="book-heart" class="position-absolute" style="color: #6a9c78; opacity: 0.1; width: 100px; height: 100px; right: -20px; bottom: -20px;"></i>
                    <h5 class="fw-bold mb-1" style="color: var(--text-main);">@ViewBag.MostPracticedBook</h5>
                    <span class="text-muted fw-bold text-uppercase mt-2" style="letter-spacing: 1px; font-size: 0.8rem;">Любимо произведение</span>
                </div>
            </div>
        </div>

        <h4 class="fw-bold mb-3" style="color: var(--text-main);">История на решаванията</h4>

        <div class="row">
            @foreach (var result in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="custom-card h-100 p-4" style="border-left: 4px solid @(result.Percentage >= (result.Test?.PassingScore ?? 60) ? "#198754" : "#dc3545") !important;">

                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="fw-bold mb-1" style="color: var(--text-main);">@(result.Test?.Title ?? "Тренировъчен тест")</h5>
                                <p class="text-muted small mb-0">@(result.Test?.Book?.Title ?? "Железният светилник") @(result.Test?.Book?.Author?.Name != null ? $"- {result.Test.Book.Author.Name}" : "")</p>
                            </div>
                            <span class="badge rounded-pill" style="font-size: 1rem; background-color: @(result.Percentage >= (result.Test?.PassingScore ?? 60) ? "rgba(25, 135, 84, 0.1)" : "rgba(220, 53, 69, 0.1)"); color: @(result.Percentage >= (result.Test?.PassingScore ?? 60) ? "#198754" : "#dc3545"); border: 1px solid @(result.Percentage >= (result.Test?.PassingScore ?? 60) ? "#198754" : "#dc3545");">
                                @result.Percentage.ToString("0.0")%
                            </span>
                        </div>

                        <div class="row text-center mb-3">
                            <div class="col-4">
                                <div class="fw-bold" style="color: #6a9c78;">@result.CorrectAnswers / @result.TotalQuestions</div>
                                <small class="text-muted">Верни</small>
                            </div>
                            <div class="col-4">
                                <div class="fw-bold" style="color: #6a9c78;">@result.Score</div>
                                <small class="text-muted">Точки</small>
                            </div>
                            <div class="col-4">
                                <div class="fw-bold" style="color: @(result.Percentage >= (result.Test?.PassingScore ?? 60) ? "#198754" : "#dc3545");">
                                    @(result.Percentage >= (result.Test?.PassingScore ?? 60) ? "Успех" : "Слаб")
                                </div>
                                <small class="text-muted">Статус</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <small class="text-muted fw-bold">Прогрес:</small>
                            <div class="progress mt-1" style="height: 8px; background-color: var(--bg-body);">
                                <div class="progress-bar rounded-pill"
                                     style="width: @result.Percentage%; background-color: @(result.Percentage >= (result.Test?.PassingScore ?? 60) ? "#198754" : "#dc3545");">
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-3 pt-3" style="border-top: 1px solid var(--border-color);">
                            <small class="text-muted">
                                <i data-lucide="calendar" style="width: 14px; height: 14px;"></i> @result.CompletedAt.ToString("dd.MM.yyyy HH:mm")
                            </small>

                            <div class="d-flex gap-2">
                                @if (result.TestId > 0)
                                {
                                    <a href="@Url.Action("Start", new { id = result.TestId })" class="btn btn-sm btn-hover-gray fw-bold px-3">
                                        <i data-lucide="rotate-ccw" style="width: 14px; height: 14px;"></i> Пак
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="PracticeTest" class="btn btn-sm btn-hover-gray fw-bold px-3">
                                        <i data-lucide="rotate-ccw" style="width: 14px; height: 14px;"></i> Пак
                                    </a>
                                }

                                <a href="@Url.Action("Results", new { id = result.Id })" class="btn btn-sm btn-hover-green fw-bold px-3">
                                    Детайли
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="custom-card p-5 text-center shadow-sm">
            <div class="d-inline-flex justify-content-center align-items-center rounded-circle mb-4" style="width: 80px; height: 80px; background-color: var(--bg-body); border: 2px dashed var(--border-color);">
                <i data-lucide="ghost" style="color: var(--text-muted); width: 40px; height: 40px;"></i>
            </div>
            <h4 class="fw-bold mb-3" style="color: var(--text-main);">Все още нямаш решени тестове</h4>
            <p class="text-muted mb-4">Време е да провериш знанията си и да напълниш това табло със статистики!</p>
            <div class="d-flex justify-content-center gap-3">
                <a href="@Url.Action("Index")" class="btn btn-hover-green py-2 px-4 fw-bold">
                    <i data-lucide="library" class="me-2"></i> Към всички тестове
                </a>
                <a asp-action="PracticeTest" class="btn btn-hover-gray py-2 px-4 fw-bold">
                    <i data-lucide="zap" class="me-2"></i> Бърза тренировка
                </a>
            </div>
        </div>
    }
</div>

<style>
    /* Класовете за бутоните, за да съвпадат навсякъде */
    .btn-hover-green {
        background-color: #6a9c78;
        color: white;
        border: 1px solid #6a9c78;
        border-radius: 12px;
        transition: all 0.2s ease-in-out;
    }

        .btn-hover-green:hover {
            background-color: #558061;
            border-color: #558061;
            color: white;
        }

    .btn-hover-gray {
        background-color: var(--bg-body);
        color: var(--text-main);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        transition: all 0.2s ease-in-out;
    }

        .btn-hover-gray:hover {
            background-color: #f3f4f6;
            border-color: #d1d5db;
            color: var(--text-main);
        }

    .custom-outline-btn:focus, .custom-outline-btn:active {
        outline: none !important;
        box-shadow: none !important;
        background-color: rgba(106, 156, 120, 0.1) !important;
    }

    .custom-outline-btn:hover {
        background-color: var(--primary) !important;
        color: white !important;
    }

    /* 1. Стил за бутона в нотификацията (Тоуста) - чисто зелено */
    .btn-toast-custom {
        border: 2px solid var(--primary);
        color: var(--primary);
        background-color: transparent;
        transition: all 0.2s ease-in-out;
    }

        .btn-toast-custom:hover {
            background-color: var(--primary);
            color: white !important;
        }
</style>

@section Scripts {
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }

        // Показване на Toast нотификацията
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(function() {
                var toastEl = document.getElementById('recommendationToast');
                if (toastEl) {
                    var toast = new bootstrap.Toast(toastEl);
                    toast.show();
                }
            }, 1500);
        });
    </script>
}