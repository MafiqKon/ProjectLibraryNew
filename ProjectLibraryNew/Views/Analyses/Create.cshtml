@model ProjectLibrary.Models.Analysis

@{
    ViewData["Title"] = "Добавяне на анализ";
}

<div class="container mt-4 mb-5" style="max-width: 800px;">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" asp-route-bookId="@ViewBag.BookId" class="btn btn-outline-secondary rounded-pill fw-bold shadow-sm hover-scale me-3" style="padding: 8px 16px;">
            <i data-lucide="arrow-left" class="me-1" style="width: 18px;"></i> Назад
        </a>
        <h2 class="fw-bold mb-0" style="color: var(--text-main);">Нов анализ</h2>
    </div>

    <div class="custom-card p-4 p-md-5 shadow-sm">
        <form asp-action="Create">
            <input type="hidden" name="BookId" value="@ViewBag.BookId" />

            <div class="mb-4">
                <label asp-for="Content" class="form-label fw-bold text-muted text-uppercase small"><i data-lucide="align-left" class="me-1" style="width:14px;"></i> Текст на анализа</label>
                <textarea asp-for="Content" class="form-control rounded-4 p-4 shadow-sm" rows="12" placeholder="Напишете детайлен анализ тук..." style="background-color: var(--bg-body); border: 1px solid var(--border-color); color: var(--text-main); font-size: 1.05rem; line-height: 1.6;" required></textarea>
                <span asp-validation-for="Content" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary fw-bold rounded-pill px-5 py-2 shadow-sm hover-scale d-flex align-items-center">
                    <i data-lucide="save" class="me-2" style="width: 18px;"></i> Запази анализа
                </button>
            </div>
        </form>
    </div>
</div>