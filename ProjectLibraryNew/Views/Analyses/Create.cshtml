@model ProjectLibrary.Models.Analysis

@{
    ViewData["Title"] = "Нов анализ";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="d-flex align-items-center mb-4">
                <button onclick="history.back()" class="btn btn-outline-secondary rounded-pill me-3">
                    <i data-lucide="arrow-left" style="width: 18px;"></i> Назад
                </button>
                <h2 class="fw-bold mb-0">📝 Нов анализ</h2>
            </div>

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-body p-5" style="background-color: var(--bg-card);">
                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="BookId" value="@ViewBag.BookId" />

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold small text-uppercase">
                                <i data-lucide="type" class="me-1" style="width: 16px;"></i> Заглавие на темата
                            </label>
                            <input asp-for="Title" class="form-control rounded-pill px-3 shadow-sm"
                                   placeholder="Напр. Исторически контекст или Образът на героя" required
                                   style="background-color: var(--bg-body); color: var(--text-main); border: 1px solid var(--border-color);" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Content" class="form-label fw-bold small text-uppercase">
                                <i data-lucide="align-left" class="me-1" style="width: 16px;"></i> Текст на анализа
                            </label>
                            <textarea asp-for="Content" class="form-control rounded-4 p-3 shadow-sm" rows="15"
                                      placeholder="Напишете детайлен анализ тук..." required
                                      style="background-color: var(--bg-body); color: var(--text-main); border: 1px solid var(--border-color);"></textarea>
                            <span asp-validation-for="Content" class="text-danger small"></span>
                        </div>

                        <div class="text-end mt-4">
                            <button type="submit" class="btn btn-success rounded-pill px-5 py-2 fw-bold hover-scale">
                                <i data-lucide="save" class="me-2" style="width: 20px;"></i> Запази анализа
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}