@model ProjectLibrary.Models.Comment
@inject Microsoft.AspNetCore.Identity.UserManager<ProjectLibrary.Models.ApplicationUser> UserManager

<div class="mb-3 comment-thread" id="comment-@Model.Id">

    <div class="custom-card p-3 shadow-sm" style="background-color: var(--bg-card); border: 1px solid var(--border-color); border-radius: 16px;">
        <div class="d-flex gap-3">

            <div class="flex-shrink-0">
                @if (!string.IsNullOrEmpty(Model.User?.ProfilePictureUrl))
                {
                    <img src="@Model.User.ProfilePictureUrl" class="rounded-circle shadow-sm" style="width: 42px; height: 42px; object-fit: cover; border: 2px solid var(--bg-body);" alt="Avatar">
                }
                else
                {
                    <div class="rounded-circle shadow-sm d-flex justify-content-center align-items-center" style="width: 42px; height: 42px; background-color: var(--bg-body); color: var(--text-muted); border: 1px solid var(--border-color);">
                        <i data-lucide="user" style="width: 20px; height: 20px;"></i>
                    </div>
                }
            </div>

            <div class="flex-grow-1">

                <div class="d-flex justify-content-between align-items-center mb-1">
                    <div class="d-flex align-items-center flex-wrap gap-2">
                        <strong style="color: var(--text-main); font-size: 0.95rem;">@Model.User?.FirstName @Model.User?.LastName</strong>

                        @if (Model.User != null)
                        {
                            @if (await UserManager.IsInRoleAsync(Model.User, "Admin"))
                            {
                                <span class="badge bg-danger rounded-pill shadow-sm" style="font-size:0.65em; letter-spacing: 0.5px;">ADMIN</span>
                            }
                            else if (await UserManager.IsInRoleAsync(Model.User, "Teacher"))
                            {
                                <span class="badge bg-warning text-dark rounded-pill shadow-sm" style="font-size:0.65em; letter-spacing: 0.5px;">TEACHER</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill shadow-sm" style="font-size:0.65em; letter-spacing: 0.5px;">STUDENT</span>
                            }
                        }
                    </div>
                    <small class="text-muted" style="font-size: 0.8rem;">@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</small>
                </div>

                <p class="mb-2 mt-2" style="color: var(--text-main); line-height: 1.5; font-size: 0.95rem;">@Model.Content</p>

                <div class="mt-2 d-flex gap-4">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <button class="btn btn-sm btn-link text-decoration-none p-0 d-flex align-items-center fw-bold hover-scale"
                                style="color: var(--primary); font-size: 0.85rem;"
                                onclick="toggleReplyForm(@Model.Id)">
                            <i data-lucide="corner-down-right" class="me-1" style="width: 16px; height: 16px;"></i> Отговори
                        </button>
                    }

                    @if (User.Identity.IsAuthenticated && (Model.UserId == UserManager.GetUserId(User) || User.IsInRole("Admin")))
                    {
                        <form asp-controller="Comments" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-link text-danger text-decoration-none p-0 d-flex align-items-center fw-bold hover-scale"
                                    style="font-size: 0.85rem;"
                                    onclick="return confirm('Сигурни ли сте, че искате да изтриете този коментар?')">
                                <i data-lucide="trash-2" class="me-1" style="width: 16px; height: 16px;"></i> Изтрий
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <div id="reply-form-@Model.Id" class="reply-form-container d-none mt-2 ms-4 mb-3">
        <form asp-controller="Comments" asp-action="Create" method="post" class="d-flex gap-2 ajax-comment-form">
            <input type="hidden" name="bookId" value="@Model.BookId" />
            <input type="hidden" name="parentCommentId" value="@Model.Id" />

            <input type="text" name="content" class="form-control form-control-sm rounded-pill px-3 shadow-sm"
                   placeholder="Напиши отговор..." required style="background-color: var(--bg-card); color: var(--text-main); border: 1px solid var(--border-color);" />

            <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm d-flex align-items-center hover-scale">
                <i data-lucide="send" class="me-1" style="width: 14px; height: 14px;"></i> Изпрати
            </button>
        </form>
    </div>

    @if (Model.Replies != null && Model.Replies.Any())
    {
        var replyCount = Model.Replies.Count;

        <button class="btn btn-sm d-lg-none mt-2 mb-3 ms-3 d-flex align-items-center fw-bold mobile-reply-toggle"
                style="color: var(--primary); background-color: var(--bg-card); border: 1px solid var(--border-color); border-radius: 8px;"
                data-count="@replyCount"
                onclick="toggleMobileReplies('replies-container-@Model.Id', this)">
            <i data-lucide="message-square-plus" class="me-2" style="width: 16px;"></i> Виж @replyCount отговор@(replyCount == 1 ? "а" : "и")
        </button>

        <div id="replies-container-@Model.Id" class="replies-wrapper d-none d-lg-block mt-2 ms-3 ps-3 ms-md-4 ps-md-4">
            @foreach (var reply in Model.Replies.OrderBy(r => r.CreatedDate))
            {
                <partial name="_CommentPartial" model="reply" />
            }
        </div>
    }
    else
    {
        <div id="replies-container-@Model.Id" class="replies-wrapper d-none d-lg-block mt-2 ms-3 ps-3 ms-md-4 ps-md-4">
        </div>
    }
</div>

<style>
    /* 1. Защита за компютри: Спираме безкрайното отместване надясно след 3-тото ниво */
    .replies-wrapper .replies-wrapper .replies-wrapper {
        margin-left: 0 !important;
        padding-left: 1rem !important;
        border-left: 2px solid var(--primary) !important;
    }

    /* 2. Обща стилизация на нишката (Линията отляво) */
    .replies-wrapper {
        border-left: 1px solid var(--border-color);
        transition: all 0.3s ease-in-out;
    }

    /* 3. Анимация при показване на телефон */
    .show-replies-mobile {
        display: block !important;
        animation: slideDownFade 0.3s ease-out forwards;
    }

    @@keyframes slideDownFade {
        0% {
            opacity: 0;
            transform: translateY(-10px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>