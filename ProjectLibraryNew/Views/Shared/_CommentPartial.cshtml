@model ProjectLibrary.Models.Comment
@inject Microsoft.AspNetCore.Identity.UserManager<ProjectLibrary.Models.ApplicationUser> UserManager

<div class="mb-3 comment-thread" id="comment-@Model.Id">

    <div class="custom-card p-3 shadow-sm comment-box transition-all" id="comment-box-@Model.Id" style="background-color: var(--bg-card); border: 1px solid var(--border-color); border-radius: 16px;">
        <div class="d-flex gap-3">

            <div class="flex-shrink-0">
                @if (!string.IsNullOrEmpty(Model.User?.ProfilePictureUrl))
                {
                    <img src="@Model.User.ProfilePictureUrl" class="rounded-circle shadow-sm" style="width: 42px; height: 42px; object-fit: cover; border: 2px solid var(--bg-body);" alt="Avatar">
                }
                else
                {
                    <div class="rounded-circle shadow-sm d-flex justify-content-center align-items-center" style="width: 42px; height: 42px; background-color: var(--bg-body); color: var(--text-muted); border: 1px solid var(--border-color);">
                        <i data-lucide="user" style="width: 20px; height: 20px;"></i>
                    </div>
                }
            </div>

            <div class="flex-grow-1">

                <div class="d-flex justify-content-between align-items-center mb-1">
                    <div class="d-flex align-items-center flex-wrap gap-2">
                        <strong style="color: var(--text-main); font-size: 0.95rem;">@Model.User?.FirstName @Model.User?.LastName</strong>

                        @if (Model.User != null)
                        {
                            @if (await UserManager.IsInRoleAsync(Model.User, "Admin"))
                            {
                                <span class="badge bg-danger rounded-pill shadow-sm" style="font-size:0.65em; letter-spacing: 0.5px;">ADMIN</span>
                            }
                            else if (await UserManager.IsInRoleAsync(Model.User, "Teacher"))
                            {
                                <span class="badge bg-warning text-dark rounded-pill shadow-sm" style="font-size:0.65em; letter-spacing: 0.5px;">TEACHER</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill shadow-sm" style="font-size:0.65em; letter-spacing: 0.5px;">STUDENT</span>
                            }
                        }
                    </div>
                    <small class="text-muted" style="font-size: 0.8rem;">@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</small>
                </div>

                @if (ViewData["ParentName"] != null && Model.ParentCommentId != null)
                {
                    <div class="mb-2 mt-1 d-inline-flex align-items-center" style="font-size: 0.8rem; background-color: rgba(150,150,150,0.08); padding: 4px 10px; border-radius: 8px;">
                        <i data-lucide="corner-down-right" class="me-1 text-muted" style="width: 14px; height: 14px;"></i>
                        <span class="text-muted me-1">Отговор на</span>
                        <a href="javascript:void(0)" onclick="scrollToTargetComment(@Model.ParentCommentId)" class="text-decoration-none fw-bold" style="color: var(--primary); transition: opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">@ViewData["ParentName"]</a>
                    </div>
                }

                <p class="mb-2 mt-1" style="color: var(--text-main); line-height: 1.5; font-size: 0.95rem; word-break: break-word; overflow-wrap: break-word; white-space: pre-wrap;">@Model.Content</p>

                <div class="mt-2 d-flex gap-4">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <button class="btn btn-sm btn-link text-decoration-none p-0 d-flex align-items-center fw-bold hover-scale"
                                style="color: var(--primary); font-size: 0.85rem;"
                                onclick="handleReplyClick(@Model.Id)">
                            <i data-lucide="corner-down-right" class="me-1" style="width: 16px; height: 16px;"></i> Отговори
                        </button>
                    }

                    @if (User.Identity.IsAuthenticated && (Model.UserId == UserManager.GetUserId(User) || User.IsInRole("Admin")))
                    {
                        <form asp-controller="Comments" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-link text-danger text-decoration-none p-0 d-flex align-items-center fw-bold hover-scale"
                                    style="font-size: 0.85rem;"
                                    onclick="return confirm('Сигурни ли сте, че искате да изтриете този коментар?')">
                                <i data-lucide="trash-2" class="me-1" style="width: 16px; height: 16px;"></i> Изтрий
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <div id="reply-form-@Model.Id" class="reply-form-container d-none mt-2 ms-lg-4 mb-3">
        <form asp-controller="Comments" asp-action="Create" method="post" class="d-flex gap-2 ajax-comment-form w-100 align-items-start">
            <input type="hidden" name="bookId" value="@Model.BookId" />
            <input type="hidden" name="parentCommentId" value="@Model.Id" />

            <div class="position-relative flex-grow-1">
                <textarea name="content" maxlength="1000" rows="2" class="form-control form-control-sm rounded-4 px-3 py-2 shadow-sm"
                          placeholder="Напиши отговор... (Enter за изпращане, Shift+Enter за нов ред)"
                          required
                          style="background-color: var(--bg-card); color: var(--text-main); border: 1px solid var(--border-color); padding-right: 90px !important; resize: none;"
                          oninput="updateCharCount(this, 'reply-counter-@Model.Id')"
                          onkeydown="if(event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); this.closest('form').querySelector('button[type=submit]').click(); }"></textarea>

                <small id="reply-counter-@Model.Id" class="text-muted position-absolute end-0 bottom-0 pe-3 pb-2 fw-bold" style="font-size: 0.7rem; pointer-events: none; opacity: 0.6; transition: color 0.3s;">0 / 1000</small>
            </div>

            <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3 py-2 fw-bold shadow-sm d-flex align-items-center hover-scale flex-shrink-0 mt-1">
                <i data-lucide="send" class="me-1" style="width: 14px; height: 14px;"></i> Изпрати
            </button>
        </form>
    </div>

    @if (Model.Replies != null && Model.Replies.Any())
    {
        var replyCount = Model.Replies.Count;

        var currentViewData = new ViewDataDictionary(ViewData);
        currentViewData["ParentName"] = Model.User?.FirstName + " " + Model.User?.LastName;
        currentViewData["ParentId"] = Model.Id;

        <button class="btn btn-sm d-lg-none mt-2 mb-3 ms-2 d-flex align-items-center fw-bold mobile-reply-toggle"
                style="color: var(--primary); background-color: var(--bg-card); border: 1px solid var(--border-color); border-radius: 8px;"
                data-count="@replyCount"
                onclick="toggleMobileReplies('replies-container-@Model.Id', this)">
            <i data-lucide="message-square-plus" class="me-2" style="width: 16px;"></i> Виж @replyCount отговор@(replyCount == 1 ? "а" : "и")
        </button>

        <div id="replies-container-@Model.Id" class="replies-wrapper d-none d-lg-block mt-2 ms-lg-3 ps-lg-3 ms-md-4 ps-md-4">
            @foreach (var reply in Model.Replies.OrderBy(r => r.CreatedDate))
            {
                <div class="mobile-reply-item">
                    <partial name="_CommentPartial" model="reply" view-data="currentViewData" />
                </div>
            }
        </div>
    }
    else
    {
        <div id="replies-container-@Model.Id" class="replies-wrapper d-none d-lg-block mt-2 ms-lg-3 ps-lg-3 ms-md-4 ps-md-4">
        </div>
    }
</div>

<style>
    .highlight-comment {
        background-color: rgba(16, 185, 129, 0.15) !important;
        border-color: var(--primary) !important;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.3) !important;
        transform: scale(1.01);
    }

    .transition-all {
        transition: all 0.5s ease-in-out;
    }

    /* Спираме безкрайното смачкване надясно */
    .replies-wrapper .replies-wrapper {
        margin-left: 15px !important;
        padding-left: 15px !important;
    }

        .replies-wrapper .replies-wrapper .replies-wrapper {
            margin-left: 0 !important;
            padding-left: 10px !important;
            border-left: 2px solid rgba(16, 185, 129, 0.3) !important;
        }

            .replies-wrapper .replies-wrapper .replies-wrapper .replies-wrapper {
                border-left: none !important;
                padding-left: 0 !important;
            }

    .replies-wrapper {
        border-left: 1px solid var(--border-color);
        transition: all 0.3s ease-in-out;
    }

    .show-replies-mobile {
        display: block !important;
        animation: slideDownFade 0.3s ease-out forwards;
    }

    @@keyframes slideDownFade {
        0% {
            opacity: 0;
            transform: translateY(-10px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 991px) {
        .replies-wrapper {
            border-left: none !important;
            margin-left: 0 !important;
            padding-left: 0 !important;
        }

        .reply-form-container {
            margin-left: 0 !important;
            margin-right: 0 !important;
        }

        .mobile-reply-item > .comment-thread > .comment-box {
            background-color: rgba(150, 150, 150, 0.03) !important;
            border: 1px dashed var(--border-color) !important;
            border-left: 4px solid var(--primary) !important;
            margin-top: 10px;
        }
    }
</style>

<script>
    function handleReplyClick(commentId) {
        if (typeof toggleReplyForm === 'function') {
            toggleReplyForm(commentId);
        }

        // Показваме формата и фокусираме текстовото поле
        const formContainer = document.getElementById('reply-form-' + commentId);
        if(formContainer && !formContainer.classList.contains('d-none')) {
            const input = formContainer.querySelector('textarea');
            if(input) {
                input.focus();
                // Центрираме формата на екрана
                formContainer.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }
    }

    // НОВО: Функция, която центрира оригиналния коментар на екрана!
    if (typeof scrollToTargetComment !== 'function') {
        window.scrollToTargetComment = function(commentId) {
            const commentBox = document.getElementById('comment-box-' + commentId);
            if (commentBox) {

                // Магията за перфектно центриране на екрана
                commentBox.scrollIntoView({ behavior: 'smooth', block: 'center' });

                // Слагаме му класа за присветване
                commentBox.classList.add('highlight-comment');

                // Махаме класа след 2 секунди
                setTimeout(() => {
                    commentBox.classList.remove('highlight-comment');
                }, 2000);
            }
        };
    }

    function toggleMobileReplies(containerId, btn) {
        const container = document.getElementById(containerId);
        if (container) {
            container.classList.toggle('show-replies-mobile');
            const isShowing = container.classList.contains('show-replies-mobile');
            const count = btn.getAttribute('data-count');

            if (isShowing) {
                btn.innerHTML = `<i data-lucide="chevron-up" class="me-2" style="width: 16px;"></i> Скрий отговорите`;
            } else {
                btn.innerHTML = `<i data-lucide="message-square-plus" class="me-2" style="width: 16px;"></i> Виж ${count} отговор${count == 1 ? 'а' : 'и'}`;
            }
            if (typeof lucide !== 'undefined') { lucide.createIcons(); }
        }
    }

    if (typeof updateCharCount !== 'function') {
        window.updateCharCount = function(inputElement, counterId) {
            const maxLength = inputElement.getAttribute('maxlength') || 1000;
            const currentLength = inputElement.value.length;
            const counterElement = document.getElementById(counterId);

            if (counterElement) {
                counterElement.textContent = `${currentLength} / ${maxLength}`;

                if (currentLength >= maxLength * 0.9) {
                    counterElement.classList.remove('text-muted');
                    counterElement.style.color = '#dc3545';
                    counterElement.style.opacity = '1';
                } else {
                    counterElement.classList.add('text-muted');
                    counterElement.style.color = '';
                    counterElement.style.opacity = '0.6';
                }
            }
        };
    }
</script>