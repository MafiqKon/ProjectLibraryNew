@model ProjectLibrary.Models.Author

@{
    ViewData["Title"] = "Добави нов автор";
}

<div class="container mt-5 mb-5" style="max-width: 700px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: var(--primary);">
            <i data-lucide="user-plus" class="me-2"></i> @ViewData["Title"]
        </h2>
        <a asp-controller="Admin" asp-action="Authors" class="btn btn-outline-secondary rounded-pill fw-bold hover-scale">
            <i data-lucide="arrow-left" class="me-1"></i> Назад
        </a>
    </div>

    <div class="custom-card p-4 p-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-4">
                <label asp-for="Name" class="form-label fw-bold" style="color: var(--text-main);">Име на автора <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control rounded-pill px-3" required placeholder="Напр. Иван Вазов" style="background-color: var(--bg-body); color: var(--text-main); border-color: var(--border-color);" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="ImageUrl" class="form-label fw-bold" style="color: var(--text-main);">Линк към снимка (URL)</label>
                <input asp-for="ImageUrl" class="form-control rounded-pill px-3" placeholder="https://..." style="background-color: var(--bg-body); color: var(--text-main); border-color: var(--border-color);" />
                <small class="text-muted ms-2 mt-1 d-block">Ако оставиш празно, ще се показва стандартна иконка.</small>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Biography" class="form-label fw-bold" style="color: var(--text-main);">Биография</label>
                <textarea asp-for="Biography" class="form-control rounded-4 p-3" rows="8" placeholder="Въведи биографията тук..." style="background-color: var(--bg-body); color: var(--text-main); border-color: var(--border-color);"></textarea>
            </div>

            <hr style="border-color: var(--border-color);" class="my-4" />

            <div class="text-end">
                <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm hover-scale">
                    <i data-lucide="save" class="me-2" style="width: 18px;"></i> Създай автор
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}