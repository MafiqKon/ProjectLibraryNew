@page
@model RegisterModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5 col-lg-5">

        <div class="card shadow-sm border-0" style="background-color: var(--bg-card); border-radius: 16px;">
            <div class="card-body p-4 p-md-5">

                <div class="text-center mb-4">
                    <div class="d-inline-flex justify-content-center align-items-center rounded-circle mb-3 shadow-sm" style="width: 65px; height: 65px; background-color: var(--bg-body); border: 2px solid var(--border-color);">
                        <i data-lucide="user-plus" style="color: var(--primary); width: 32px; height: 32px;"></i>
                    </div>
                    <h3 class="fw-bold" style="color: var(--text-main);">Нов профил</h3>
                    <p class="text-muted small">Присъединете се към нашата библиотека.</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold" role="alert"></div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div class="form-floating">
                                <input asp-for="Input.FirstName" class="form-control rounded-3" autocomplete="given-name" aria-required="true" placeholder="Иван" style="background-color: var(--bg-body); border-color: var(--border-color); color: var(--text-main);" />
                                <label asp-for="Input.FirstName" class="text-muted"><i data-lucide="type" style="width: 16px; height: 16px; margin-top: -3px;"></i> Име</label>
                            </div>
                            <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <div class="form-floating">
                                <input asp-for="Input.LastName" class="form-control rounded-3" autocomplete="family-name" aria-required="true" placeholder="Иванов" style="background-color: var(--bg-body); border-color: var(--border-color); color: var(--text-main);" />
                                <label asp-for="Input.LastName" class="text-muted"><i data-lucide="type" style="width: 16px; height: 16px; margin-top: -3px;"></i> Фамилия</label>
                            </div>
                            <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" aria-required="true" placeholder="name@example.com" style="background-color: var(--bg-body); border-color: var(--border-color); color: var(--text-main);" />
                        <label asp-for="Input.Email" class="text-muted"><i data-lucide="mail" style="width: 16px; height: 16px; margin-top: -3px;"></i> Имейл адрес</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3 position-relative">
                        <input asp-for="Input.Password" id="passwordInputReg" class="form-control rounded-3 pe-5" autocomplete="new-password" aria-required="true" placeholder="password" style="background-color: var(--bg-body); border-color: var(--border-color); color: var(--text-main);" />
                        <label asp-for="Input.Password" class="text-muted"><i data-lucide="lock" style="width: 16px; height: 16px; margin-top: -3px;"></i> Парола</label>

                        <span class="position-absolute top-50 end-0 translate-middle-y me-3 text-muted password-toggle-btn" id="togglePasswordReg" style="cursor: pointer; z-index: 10;">
                            <i data-lucide="eye" id="eyeIconReg" style="width: 20px; height: 20px; transition: color 0.2s;"></i>
                        </span>

                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.ConfirmPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="password" style="background-color: var(--bg-body); border-color: var(--border-color); color: var(--text-main);" />
                        <label asp-for="Input.ConfirmPassword" class="text-muted"><i data-lucide="check-circle" style="width: 16px; height: 16px; margin-top: -3px;"></i> Потвърдете паролата</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="custom-card p-3 mb-4" style="background-color: rgba(245, 158, 11, 0.05); border: 1px dashed #f59e0b; border-radius: 12px;">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input me-3" asp-for="Input.RequestTeacherRole" style="cursor: pointer; width: 20px; height: 20px; border-color: #f59e0b;" />
                            <label asp-for="Input.RequestTeacherRole" class="form-check-label fw-bold" style="cursor: pointer; color: var(--text-main);">
                                Аз съм учител <br />
                                <span class="text-muted fw-normal" style="font-size: 0.8rem;">Профилът Ви ще изисква одобрение от администратор.</span>
                            </label>
                        </div>
                    </div>

                    <div>
                        <button id="registerSubmit" type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-pill d-flex justify-content-center align-items-center shadow-sm" style="font-size: 1.1rem; transition: transform 0.2s ease;">
                            <i data-lucide="user-plus" class="me-2"></i> Регистрирай се
                        </button>
                    </div>

                    <div class="mt-4 text-center">
                        <p class="mb-0 text-muted small">
                            Вече имате профил? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold" style="color: var(--primary); text-decoration: none; border-bottom: 1px dashed var(--primary);">Влезте от тук</a>
                        </p>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>

<style>
    .password-toggle-btn:hover #eyeIconReg {
        color: var(--primary) !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }

        // Логика за оченцето на паролата
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('togglePasswordReg');
            const passInput = document.getElementById('passwordInputReg');
            const eyeIcon = document.getElementById('eyeIconReg');

            if (toggleBtn && passInput) {
                toggleBtn.addEventListener('click', function () {
                    const type = passInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passInput.setAttribute('type', type);

                    if (type === 'text') {
                        eyeIcon.setAttribute('data-lucide', 'eye-off');
                    } else {
                        eyeIcon.setAttribute('data-lucide', 'eye');
                    }
                    lucide.createIcons();
                });
            }
        });
    </script>
}