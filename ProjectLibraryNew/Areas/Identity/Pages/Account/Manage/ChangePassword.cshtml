@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Смяна на парола";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h4 class="fw-bold mb-2" style="color: var(--text-main);">@ViewData["Title"]</h4>
<p class="text-muted mb-4 pb-3" style="border-bottom: 2px solid var(--border-color); font-size: 0.9rem;">
    Запазете акаунта си сигурен, като използвате силна парола с букви, цифри и символи.
</p>
<partial name="_StatusMessage" for="StatusMessage" />

<form id="change-password-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="form-group mb-4">
        <label asp-for="Input.OldPassword" class="form-label fw-bold small text-uppercase mb-1" style="color: var(--text-main);">Текуща парола <span class="text-danger">*</span></label>
        <div class="input-group shadow-sm rounded-pill overflow-hidden" style="border: 1px solid var(--border-color); background-color: var(--bg-body);">
            <span class="input-group-text border-0 bg-transparent text-muted">
                <i data-lucide="lock" style="width: 18px;"></i>
            </span>
            <input asp-for="Input.OldPassword" class="form-control border-0 px-3 bg-transparent" autocomplete="current-password" aria-required="true" style="color: var(--text-main);" />
        </div>
        <span asp-validation-for="Input.OldPassword" class="text-danger small mt-1 d-block ms-3"></span>
    </div>

    <div class="form-group mb-4">
        <label asp-for="Input.NewPassword" class="form-label fw-bold small text-uppercase mb-1" style="color: var(--text-main);">Нова парола <span class="text-danger">*</span></label>
        <div class="input-group shadow-sm rounded-pill overflow-hidden" style="border: 1px solid var(--border-color); background-color: var(--bg-body);">
            <span class="input-group-text border-0 bg-transparent text-primary">
                <i data-lucide="key-round" style="width: 18px;"></i>
            </span>
            <input asp-for="Input.NewPassword" class="form-control border-0 px-3 bg-transparent" autocomplete="new-password" aria-required="true" style="color: var(--text-main);" />
        </div>
        <span asp-validation-for="Input.NewPassword" class="text-danger small mt-1 d-block ms-3"></span>
    </div>

    <div class="form-group mb-4">
        <label asp-for="Input.ConfirmPassword" class="form-label fw-bold small text-uppercase mb-1" style="color: var(--text-main);">Потвърди новата парола <span class="text-danger">*</span></label>
        <div class="input-group shadow-sm rounded-pill overflow-hidden" style="border: 1px solid var(--border-color); background-color: var(--bg-body);">
            <span class="input-group-text border-0 bg-transparent text-success">
                <i data-lucide="shield-check" style="width: 18px;"></i>
            </span>
            <input asp-for="Input.ConfirmPassword" class="form-control border-0 px-3 bg-transparent" autocomplete="new-password" aria-required="true" style="color: var(--text-main);" />
        </div>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block ms-3"></span>
    </div>

    <button type="submit" class="btn btn-solid-premium w-100 shadow-sm mt-3 py-2 rounded-pill hover-scale" style="font-size: 1.05rem;">
        <i data-lucide="refresh-cw" class="me-2" style="width: 18px;"></i> Обнови паролата
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}