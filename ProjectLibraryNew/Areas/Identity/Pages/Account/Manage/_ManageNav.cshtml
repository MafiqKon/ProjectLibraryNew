@using ProjectLibrary.Models
@* ВАЖНО: Ако проектът ти се казва ProjectLibraryNew, промени горния ред на @using ProjectLibraryNew.Models *@

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<ul class="nav flex-column gap-2 premium-manage-nav">
    <li class="nav-item">
        <a class="nav-link rounded-pill d-flex align-items-center fw-bold @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">
            <i data-lucide="user" class="me-3" style="width: 18px;"></i> Профил
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link rounded-pill d-flex align-items-center fw-bold @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">
            <i data-lucide="mail" class="me-3" style="width: 18px;"></i> Имейл
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link rounded-pill d-flex align-items-center fw-bold @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">
            <i data-lucide="key" class="me-3" style="width: 18px;"></i> Парола
        </a>
    </li>
    @if (hasExternalLogins)
    {
        <li id="external-logins" class="nav-item">
            <a id="external-login" class="nav-link rounded-pill d-flex align-items-center fw-bold @ManageNavPages.ExternalLoginsNavClass(ViewContext)" asp-page="./ExternalLogins">
                <i data-lucide="link" class="me-3" style="width: 18px;"></i> Външни логини
            </a>
        </li>
    }
    <li class="nav-item">
        <a class="nav-link rounded-pill d-flex align-items-center fw-bold @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">
            <i data-lucide="shield" class="me-3" style="width: 18px;"></i> Двуфакторна защита
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link rounded-pill d-flex align-items-center fw-bold @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">
            <i data-lucide="database" class="me-3" style="width: 18px;"></i> Лични данни
        </a>
    </li>
</ul>

<style>
    /* СТИЛОВЕ ЗА ПРЕМИУМ МЕНЮТО */
    .premium-manage-nav .nav-link {
        color: var(--text-main);
        padding: 12px 20px;
        transition: all 0.2s ease-in-out;
        background-color: transparent;
    }

        .premium-manage-nav .nav-link:hover {
            background-color: rgba(106, 156, 120, 0.1); /* Леко зелено при ховър */
            color: var(--primary);
        }

        /* Активният таб */
        .premium-manage-nav .nav-link.active {
            background-color: var(--primary) !important;
            color: white !important;
            box-shadow: 0 4px 10px rgba(106, 156, 120, 0.3);
        }

            .premium-manage-nav .nav-link.active i {
                color: white !important;
            }
</style>

<script>
    // Зареждаме иконките, ако случайно не са заредени
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    });
</script>