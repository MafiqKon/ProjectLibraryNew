@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout))
    {
        Layout = (string)parentLayout;
    }
    else
    {
        Layout = "/Views/Shared/_Layout.cshtml";
    }
}

<div class="container mt-5 mb-5">
    <div class="d-flex align-items-center mb-5 mt-3 border-bottom pb-3" style="border-color: var(--border-color) !important;">
        <div class="d-flex justify-content-center align-items-center rounded-3 me-3" style="width: 50px; height: 50px; background-color: var(--primary); color: white; box-shadow: 0 4px 15px rgba(106, 156, 120, 0.4);">
            <i data-lucide="settings" style="width: 28px; height: 28px;"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0" style="color: var(--text-main);">Настройки на профила</h2>
            <p class="text-muted mb-0">Управлявайте вашите данни бързо и сигурно</p>
        </div>
    </div>

    <div class="row g-5">
        <div class="col-md-4 col-lg-3">
            <div class="sticky-top" style="top: 100px;">
                <partial name="_ManageNav" />
            </div>
        </div>

        <div class="col-md-8 col-lg-7">
            <div class="card border-0 shadow-sm p-4 p-md-5" style="background-color: var(--bg-card); border: 2px solid var(--border-color) !important; border-radius: 16px; transform: none !important; transition: none !important; max-width: 600px;">
                @RenderBody()
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}